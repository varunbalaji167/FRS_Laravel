APP_NAME="IIT Indore FRS"
APP_ENV=production
APP_KEY=                          # Will be generated on server
APP_DEBUG=false                   # CRITICAL: must be false in production
APP_URL=https://testfrs.iiti.ac.in
APP_PORT=443

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# LOG_CHANNEL=stack
# LOG_STACK=single
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DAILY_DAYS=30
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                  # all above log warnings in production (warnings,critical,errors)

DB_CONNECTION=mysql
DB_HOST=127.0.0.1                 # Local MySQL on the server itself
DB_PORT=3306
DB_DATABASE=frsdb     # Your CloudPanel DB name
DB_USERNAME=frsuser              # Your CloudPanel DB user
DB_PASSWORD=

# SESSION_DRIVER=cookie
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false 
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
# QUEUE_CONNECTION=database
QUEUE_CONNECTION=redis
# CACHE_STORE=database
CACHE_STORE=redis

# --- REDIS CONFIGURATION ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration 
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="your@gmail.com"
MAIL_FROM_NAME="IIT Indore FRS"

VITE_APP_NAME="${APP_NAME}"

# Google OAuth 
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://testfrs.iiti.ac.in/auth/google/callback